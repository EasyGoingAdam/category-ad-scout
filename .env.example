# --- Required ---

# Supabase Postgres. Use the "Transaction pooler" connection string
# (Project Settings → Database → Connection pooling → Transaction mode).
# Format: postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Anthropic key for category brainstorming
ANTHROPIC_API_KEY=

# --- Search provider (pick one) ---
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=

# --- Enrichment ---

# SEMrush traffic API
SEMRUSH_API_KEY=

# Hunter.io contact API
HUNTER_API_KEY=

# Meta Ad Library — webhook into your Ad Library Scout cowork skill.
# Endpoint must accept POST {brand_name, domain, category, country, search_terms}
# and return {ads_found, active_ad_count, confidence, main_offer, creative_types, top_hooks, ad_library_url}.
META_COWORK_URL=
META_COWORK_TOKEN=

# --- Optional ---

# Telegram alerts (high-quality leads)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bearer token to protect /api/cron/run when exposed to the internet.
# If unset, the endpoint is open (fine for local).
CRON_TOKEN=
